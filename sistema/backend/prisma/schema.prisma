// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Entidade Questao
model Questao {
  id          Int       @id @default(autoincrement())
  enunciado   String
  alternativas Alternativa[]
  provas      ProvaQuestao[]
  dataCriacao DateTime  @default(now())

  @@map("questoes")
}

// Entidade Alternativa
model Alternativa {
  id        Int     @id @default(autoincrement())
  questaoId Int
  questao   Questao @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  correta   Boolean
  descricao String

  @@map("alternativas")
}

// Entidade Prova
model Prova {
  id                 Int            @id @default(autoincrement())
  questoes           ProvaQuestao[]
  tipoDeResposta     String         @default("LETRAS") // "LETRAS" ou "SOMA_EXPONENCIAL"
  dataCriacao        DateTime       @default(now())
  dataModificacao    DateTime       @updatedAt
    
  @@map("provas")
}

// Tabela de junction para a relação muitos-para-muitos entre Prova e Questao
model ProvaQuestao {
  id       Int   @id @default(autoincrement())
  prova    Prova @relation(fields: [provaId], references: [id], onDelete: Cascade)
  provaId  Int
  questao  Questao @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  questaoId Int
  ordem    Int   @default(0) // Ordem da questão na prova

  @@unique([provaId, questaoId])
  @@map("prova_questoes")
}
